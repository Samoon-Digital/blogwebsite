{
    "name": "hindiline-adminpanel",
    "compatibility_date": "2026-05-19",
    "main": "src/index.ts",
    "routes": [
        {
            "pattern": "admin.hindiline.com",
            "custom_domain": true
        },
        {
            "pattern": "hindiline.com/*",
            "zone_name": "hindiline.com"
        },
        {
            "pattern": "www.hindiline.com/*",
            "zone_name": "hindiline.com"
        }
    ],
    "vars": {
        "OPENAI_TEXT_MODEL": "gpt-5.5",
        "OPENAI_IMAGE_MODEL": "gpt-image-2",
        "R2_PUBLIC_BASE_URL": "https://hindiline.com/assets"
    },
    "d1_databases": [
        {
            "database_name": "hindiline_admin",
            "database_id": "fbc21a03-3d14-4d84-891c-6d91eba8ef93",
            "binding": "ADMIN_DB"
        }
    ],
    "r2_buckets": [
        {
            "binding": "ARTICLE_IMAGES",
            "bucket_name": "hindiline-article-images"
        }
    ]
}
