{
    "name": "samoondgital-adminpanel",
    "compatibility_date": "2026-05-19",
    "main": "src/index.ts",
    "vars": {
        "SESSION_SECRET": "local-testing-secret"
    },
    "d1_databases": [
        {
            "binding": "ADMIN_DB",
            "database_name": "samoondgital_admin",
            "database_id": "local-database-id"
        }
    ]
}